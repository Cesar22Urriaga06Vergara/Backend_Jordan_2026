# Backend Jordan - ejemplo de variables
# No usar secretos reales en este archivo.

NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=dev-insecure-jwt-secret-do-not-use-in-production
JWT_EXPIRATION=1h

# CORS: separar multiples origenes con coma.
CORS_ORIGINS=http://localhost:3001

# Desarrollo local actual: MySQL/MariaDB.
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=tu_usuario_local
DB_PASSWORD=tu_password_local
DB_DATABASE=jordan
DB_SSL=false

# TypeORM
DB_SYNCHRONIZE=false
ALLOW_TYPEORM_SYNC=false
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY_MS=3000
DB_CONNECT_TIMEOUT_MS=10000

# Solo desarrollo local. Nunca activar en produccion.
ALLOW_REOPEN_DAY_IN_DEV=false

# Solo para ejecutar npm run db:prepare-production.
# No usar valores reales en este archivo.
PRODUCTION_ADMIN_EMAIL=admin@example.com
PRODUCTION_ADMIN_PASSWORD=change-me-before-running
PRODUCTION_ADMIN_NAME=Administrador Jordan
PRODUCTION_ADMIN_ROLE=ADMIN
